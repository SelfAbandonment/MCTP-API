# Django 配置
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# 数据库 (默认 SQLite, 生产环境建议 PostgreSQL)
# DATABASE_URL=postgres://user:password@localhost:5432/mctp_api

# ShowDoc 文档同步 (向管理员索取)
SHOWDOC_URL=http://your-showdoc-host:port
SHOWDOC_API_KEY=your-api-key
SHOWDOC_API_TOKEN=your-api-token
MS_CLIENT_ID=<Azure 应用 ID>
MS_CLIENT_SECRET=<密钥值>
MS_REDIRECT_URI=http://localhost:8000/api/v1/auth/microsoft/callback/
FRONTEND_OAUTH_CALLBACK=http://localhost:5173/#/auth/microsoft/callback
MS_TOKEN_FERNET_KEY=<用以下命令生成: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
